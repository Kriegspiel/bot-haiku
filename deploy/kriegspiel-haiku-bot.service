[Unit]
Description=Kriegspiel Haiku Bot
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/home/fil/dev/kriegspiel/bot-haiku
ExecStart=/home/fil/dev/kriegspiel/bot-haiku/.venv/bin/python /home/fil/dev/kriegspiel/bot-haiku/bot.py --poll-seconds 2
Restart=always
RestartSec=5

[Install]
WantedBy=default.target
